{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "templateParts": [{
        "name":"header",
	"title": "MyHeader",
	"area": "header",
	"description":"Main Header"
    }] 
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary", "color": "#0073aa", "name": "Primary" },
        { "slug": "secondary", "color": "#222222", "name": "Secondary" },
        { "slug": "accent", "color": "#f39c12", "name": "Accent" }
      ]
    },
    "typography": {
      "fontSizes": [
        { "slug": "small", "size": "14px", "name": "Small" },
        { "slug": "normal", "size": "16px", "name": "Normal" },
        { "slug": "large", "size": "24px", "name": "Large" }
      ]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "100%"
    }
  },
  "styles": {
      "elements": {
      "h1": {
        "typography": { "fontSize": "32px" },
        "color": { "text": "#0073aa" }
      },
      "h2": {
        "typography": { "fontSize": "28px" },
        "color": { "text": "#222222" }
      },
      "p": {
        "typography": { "fontSize": "16px" },
        "color": { "text": "#222222" }
      }
    },
    "blocks": {
      "core/paragraph": { "spacing": { "margin": { "bottom": "16px" } } },
      "core/heading": { "spacing": { "margin": { "bottom": "12px" } } }
    }
  }
}



